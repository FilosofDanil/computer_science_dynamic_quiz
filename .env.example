# Copy this file to .env and fill in the values below.

# ── Required ──────────────────────────────────────────────────────────────
# Your bot token from @BotFather.
TELEGRAM_BOT_TOKEN=123456:your-bot-token-from-BotFather

# PostgreSQL connection string. The bot stores all tests (quiz sets) here and
# creates the schema automatically on startup.
# Local example shown; on Railway use the provided plugin connection string.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/quizbot?sslmode=disable

# ── AI test generation (Claude) ───────────────────────────────────────────
# Anthropic API key, used by /newtest to generate tests from a description.
# Leave empty to disable AI generation (the rest of the bot still works).
# Get one at https://console.anthropic.com/ — see INSTRUCTION.md for steps.
ANTHROPIC_API_KEY=

# Optional: override the Claude model. Defaults to a fast, cheap Haiku model.
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Optional ──────────────────────────────────────────────────────────────
# Log verbosity: "debug" enables debug logs, anything else stays at "info".
# LOG_LEVEL=info

# Log format: "json" for structured logs, anything else for human-readable text.
# LOG_FORMAT=text

# Path to the curated topics JSON file. Only used by the one-shot migration
# command (cmd/migrate) that seeds the database with the bundled tests.
# TOPICS_PATH=data/topics.json
